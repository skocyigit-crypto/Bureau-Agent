{
  "expo": {
    "name": "Agent de Bureau",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "agentdebureau",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1729"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.agentdebureau.mobile"
    },
    "android": {
      "package": "fr.agentdebureau.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0f1729"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://agentdebureau.fr/"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Agent de Bureau a besoin d'acceder a votre camera pour la reconnaissance faciale."
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
