##############################################################################
# Agent de Bureau — Environment Variables Template
# Copy this file to .env and fill in all required values.
# NEVER commit your actual .env file to version control.
##############################################################################

# ===========================================================================
# DATABASE (required)
# ===========================================================================
# Standard PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://adb_user:CHANGE_ME@localhost:5432/agentdebureau

# ===========================================================================
# SESSION & SECURITY (required)
# ===========================================================================
# Long random string (min 64 chars). Generate: openssl rand -hex 64
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_64

# AES-256 backup encryption key. Generate: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ===========================================================================
# SERVER (required)
# ===========================================================================
NODE_ENV=production
PORT=8080

# Your public domain or IP (used for OAuth redirect URIs, CORS, etc.)
# Example: https://agentdebureau.example.com
APP_URL=https://YOUR_DOMAIN

# ===========================================================================
# AI PROVIDERS (at least one required for AI features)
# ===========================================================================

# --- Google Gemini ---
# Get key from: https://aistudio.google.com/app/apikey
AI_INTEGRATIONS_GEMINI_API_KEY=CHANGE_ME
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# --- OpenAI ---
# Get key from: https://platform.openai.com/api-keys
AI_INTEGRATIONS_OPENAI_API_KEY=CHANGE_ME
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic (Claude) ---
# Get key from: https://console.anthropic.com/settings/keys
AI_INTEGRATIONS_ANTHROPIC_API_KEY=CHANGE_ME
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com

# Default AI quotas per organisation per month (if not set per org in DB)
AI_DEFAULT_MONTHLY_COST_USD=50
AI_DEFAULT_MONTHLY_CALLS=5000

# ===========================================================================
# TWILIO (optional — enables voice AI receptionist + SMS)
# ===========================================================================
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ===========================================================================
# RESEND (optional — enables transactional email)
# ===========================================================================
# Get key from: https://resend.com/api-keys
RESEND_API_KEY=CHANGE_ME

# ===========================================================================
# GOOGLE OAUTH2 (optional — enables Gmail, Drive, Calendar, etc.)
# ===========================================================================
# 1. Create a project at https://console.cloud.google.com
# 2. Enable the APIs you need (Gmail, Drive, Calendar, Sheets, Docs)
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add YOUR_DOMAIN/api/google-oauth/callback as an authorized redirect URI
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME

# Full redirect URI that matches what you set in Google Cloud Console
GOOGLE_REDIRECT_URI=https://YOUR_DOMAIN/api/google-oauth/callback

# ===========================================================================
# GOOGLE DRIVE BACKUP (optional — service account for automated backups)
# ===========================================================================
# Alternative to per-user OAuth for Drive backups.
# 1. Create a Service Account in Google Cloud Console
# 2. Grant it "Editor" access to a shared Drive folder
# 3. Download the JSON key file
# 4. Base64-encode it: base64 -w0 service-account-key.json
# 5. Paste the base64 string below
GOOGLE_SERVICE_ACCOUNT_KEY_JSON_B64=

# ===========================================================================
# CORS (optional — restrict which origins can call the API)
# ===========================================================================
# Comma-separated list. Leave empty to allow APP_URL only.
# CORS_ORIGINS=https://agentdebureau.example.com,https://www.agentdebureau.example.com

# ===========================================================================
# MISC (optional)
# ===========================================================================
# Admin email used for initial seeding (see scripts/seed-admin.ts)
ADMIN_EMAIL=admin@agentdebureau.fr
ADMIN_PASSWORD=Admin2026!
