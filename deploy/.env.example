## =============================================================================
## Agent de Bureau — Environment configuration (.env)
## Copy to deploy/.env and fill in. Lines marked REQUIRED must be set.
## =============================================================================

## --- Public URL & TLS ---------------------------------------------------------
# For HTTPS with automatic Let's Encrypt certificate, set DOMAIN to your
# fully-qualified domain (e.g. app.exemple.fr) AND make sure the server's
# public ports 80 + 443 reach this Docker host.
# For local / behind-another-proxy, leave as :80.
DOMAIN=:80
PUBLIC_URL=
# Aynı amaca hizmet eden eski değişken — boş bırakın, PUBLIC_URL yeterli
APP_URL=
# Mobil uygulama derin link (e-postada görünür) — opsiyonel
MOBILE_APP_URL=
# Web uygulamasının base path'i (vitenin BASE_URL'iyle aynı). Default: /buro-ajani
APP_BASE_PATH=/buro-ajani

# ===========================================================================
# GÜVENLİK: ek şifreleme anahtarları (her biri 32+ rastgele karakter)
# ===========================================================================
# Hassas kolon şifrelemesi için (boş bırakırsanız SESSION_SECRET kullanılır)
DATA_ENCRYPTION_KEY=
# Google Drive yedekleme şifrelemesi için (boş bırakırsanız SESSION_SECRET kullanılır)
BACKUP_ENCRYPTION_KEY=
# CORS — virgülle ayrılmış izinli kaynaklar (örn: https://app.sirketim.fr,https://www.sirketim.fr)
# Boş bırakılırsa same-origin'e izin verir.
ALLOWED_ORIGINS=

# ===========================================================================
# SMTP (Gmail API yoksa email göndermek için fallback)
# ===========================================================================
# Resend kullanıyorsanız boş bırakın. SMTP doluysa Gmail API başarısız
# olduğunda nodemailer üzerinden mail gönderir.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@agentdebureau.fr

# ===========================================================================
# Caddy port mapping (default 80/443; değiştirmek istemiyorsanız dokunmayın)
# ===========================================================================
HTTP_PORT=80
HTTPS_PORT=443

## --- Database (REQUIRED) ------------------------------------------------------
POSTGRES_DB=agent_de_bureau
POSTGRES_USER=agent
POSTGRES_PASSWORD=change_me_to_a_long_random_string

## --- App secrets (REQUIRED) ---------------------------------------------------
# Generate with:  openssl rand -hex 32
SESSION_SECRET=
JWT_SECRET=

## --- First super-admin (REQUIRED on first boot) -------------------------------
ADMIN_EMAIL=admin@agentdebureau.fr
ADMIN_PASSWORD=

## --- AI providers (at least one strongly recommended) -------------------------
# Get keys from:
#   Gemini    : https://aistudio.google.com/apikey
#   OpenAI    : https://platform.openai.com/api-keys
#   Anthropic : https://console.anthropic.com/settings/keys
# Fallback order in code: Gemini -> OpenAI -> Anthropic
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

## --- Email (Resend) -----------------------------------------------------------
# https://resend.com/api-keys  — needed for outbound notifications & invites
RESEND_API_KEY=

## --- Twilio (inbound/outbound telephony) -------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

## --- Google OAuth (Gmail / Calendar / Drive integrations) ---------------------
# Create OAuth client at: https://console.cloud.google.com/apis/credentials
# After moving off Replit, replace the previous Replit redirect URI in the
# Google console with: https://<your-domain>/api/google-oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.example/api/google-oauth/callback

## --- Stripe (SaaS abonelik + otomatik fatura) ----------------------------------
# 1) https://dashboard.stripe.com → API keys → "Secret key"
# 2) Products bölümünde 3 plan oluşturun (aylık recurring, EUR):
#    - Starter   29€/ay
#    - Professionnel 79€/ay
#    - Entreprise 199€/ay
# 3) Her ürünün fiyat ID'sini (price_xxx ile başlar) aşağıya yapıştırın.
# 4) Webhooks → "Add endpoint" → URL: https://<your-domain>/api/stripe/webhook
#    Events: checkout.session.completed, customer.subscription.*, invoice.paid,
#    invoice.payment_failed → "Signing secret"i STRIPE_WEBHOOK_SECRET'e koyun.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONNEL=
STRIPE_PRICE_ENTREPRISE=
