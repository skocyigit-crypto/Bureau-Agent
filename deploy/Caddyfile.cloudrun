# Caddyfile.cloudrun — Agent de Bureau (Cloud Run variant)
#
# Cloud Run runs each service in its own isolated network — there is no
# shared Docker Compose network to resolve a bare "api:8080" hostname
# against, so unlike deploy/Caddyfile (docker-compose), this variant
# reverse-proxies to the API's real Cloud Run HTTPS URL, injected at
# container start via the API_UPSTREAM env var.
#
# Cloud Run also terminates TLS itself in front of the container and
# always talks to the container over plain HTTP on $PORT, so this Caddyfile
# never does its own TLS/ACME — it just listens on :{$PORT}.

:{$PORT:8080} {
        encode zstd gzip

        handle /api* {
                reverse_proxy {$API_UPSTREAM} {
                        header_up Host {upstream_hostport}
                }
        }

        root * /srv
        @hashed path_regexp \.[a-f0-9]{8,}\.(js|css|woff2?|png|jpe?g|gif|svg|webp|avif)$
        header @hashed Cache-Control "public, max-age=31536000, immutable"
        header /index.html Cache-Control "no-cache, no-store, must-revalidate"

        try_files {path} /index.html
        file_server

        log {
                output stdout
                format console
        }
}
