# Caddyfile.cloudrun — Ajant Bureau (Cloud Run variant)
#
# Cloud Run runs each service in its own isolated network — there is no
# shared Docker Compose network to resolve a bare "api:8080" hostname
# against, so unlike deploy/Caddyfile (docker-compose), this variant
# reverse-proxies to the API's real Cloud Run HTTPS URL, injected at
# container start via the API_UPSTREAM env var.
#
# Cloud Run also terminates TLS itself in front of the container and
# always talks to the container over plain HTTP on $PORT, so this Caddyfile
# never does its own TLS/ACME — it just listens on :{$PORT}.

:{$PORT:8080} {
        encode zstd gzip

        # Applies to every response in this site block (static + proxied /api).
        # The api-server sets its own security headers on its JSON responses
        # already (helmet), but the static SPA served directly by Caddy had
        # none of these.
        header {
                Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
                X-Content-Type-Options "nosniff"
                X-Frame-Options "DENY"
                Referrer-Policy "strict-origin-when-cross-origin"
        }

        # `handle` blocks are only mutually exclusive with OTHER `handle`/
        # `handle_path` blocks in the same scope — a bare `file_server` /
        # `try_files` left at the top level still runs for every request
        # regardless of the block above, which silently served index.html
        # for /api/* instead of proxying. Wrapping the static site in its
        # own `handle` makes the two routes properly exclusive.
        handle /api* {
                # Cloud Run's own edge always terminates TLS in front of the api
                # service, so the upstream must be dialed over HTTPS (a bare
                # host:443 defaults to plain HTTP in Caddy, which the target
                # rejects, breaking the connection with EOF).
                reverse_proxy https://{$API_UPSTREAM} {
                        header_up Host {upstream_hostport}
                        # Cloud Run's edge sets X-Forwarded-For correctly on THIS hop
                        # (client -> web service), but the NEXT hop (this reverse_proxy
                        # call -> api service's own Cloud Run edge) collapses it to a
                        # shared internal address (Cloud Run's own link-local proxy IP),
                        # not the real visitor — every web-app user then looks like the
                        # same "client" to the api service, which let one visitor's
                        # traffic burst rate-limit/ban everyone (2026-07-14 incident,
                        # see AI_AUTOMATION_ROADMAP.md). Snapshot the real value into a
                        # dedicated header before that hop; Cloud Run has no special
                        # handling for it, so it survives untouched. Backend prefers
                        # this over X-Forwarded-For (lib/request-ip.ts).
                        header_up X-Real-Client-IP {http.request.header.X-Forwarded-For}
                }
        }

        handle {
                root * /srv
                @hashed path_regexp \.[a-f0-9]{8,}\.(js|css|woff2?|png|jpe?g|gif|svg|webp|avif)$
                header @hashed Cache-Control "public, max-age=31536000, immutable"
                header /index.html Cache-Control "no-cache, no-store, must-revalidate"

                try_files {path} /index.html
                file_server
        }

        log {
                output stdout
                format console
        }
}
