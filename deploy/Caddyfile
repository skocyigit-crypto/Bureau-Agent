# Caddyfile — Ajant Bureau (Docker Compose)
#
# DOMAIN env var controls TLS. Examples:
#   DOMAIN=:80                     → HTTP only (local dev / behind another proxy)
#   DOMAIN=app.exemple.fr          → automatic Let's Encrypt HTTPS
#
# All /api/* requests are reverse-proxied to the api container.
# Everything else is served from /srv (built React SPA) with HTML5 fallback.

{$DOMAIN:":80"} {
        encode zstd gzip

        # Applies to every response in this site block (static + proxied /api).
        # Browsers ignore Strict-Transport-Security on plain-HTTP responses, so
        # this is a safe no-op for local/dev DOMAIN=:80 setups and only takes
        # effect once DOMAIN is a real HTTPS domain.
        header {
                Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
                X-Content-Type-Options "nosniff"
                X-Frame-Options "DENY"
                Referrer-Policy "strict-origin-when-cross-origin"
        }

        # Forward API calls to the Node backend.
        # IMPORTANT: do NOT use handle_path here — Express mounts routes under /api
        # and expects the /api prefix to be preserved. `handle` keeps the URL intact.
        handle /api* {
                reverse_proxy api:8080
        }

        # `handle` is only mutually exclusive with OTHER handle/handle_path
        # blocks — a bare file_server/try_files at the top level still runs
        # for every request regardless of the block above, which would
        # silently serve index.html for /api/* instead of proxying it.
        # Wrapping the static site in its own `handle` makes the two routes
        # properly exclusive.
        handle {
                # Static SPA — long cache for hashed assets, no-cache for HTML
                root * /srv
                @hashed path_regexp \.[a-f0-9]{8,}\.(js|css|woff2?|png|jpe?g|gif|svg|webp|avif)$
                header @hashed Cache-Control "public, max-age=31536000, immutable"
                header /index.html Cache-Control "no-cache, no-store, must-revalidate"

                # SPA history fallback
                try_files {path} /index.html
                file_server
        }

        log {
                output stdout
                format console
        }
}
