# Copy to .env for local development. NEVER point this at the production
# database from a dev machine without an explicit, deliberate decision —
# see plan decision #2/#3 (same-DB assumption, strangler-fig vs cutover).

ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent_de_bureau_dev

# Session/token signing. Comma-separated, newest first, for zero-downtime
# rotation — mirrors the Node service's SESSION_SECRETS convention exactly.
SESSION_SECRETS=dev-secret-change-me-please-0000000000000000

# Required in production for AES-256-GCM at-rest encryption (api keys, etc).
# Falls back to SESSION_SECRETS[0] outside production only.
DATA_ENCRYPTION_KEY=

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:19006

DB_STATEMENT_TIMEOUT_MS=30000
DB_LOCK_TIMEOUT_MS=5000
DB_IDLE_IN_TX_TIMEOUT_MS=60000
