{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "test": "pnpm -r --if-present --workspace-concurrency=1 run test",
    "test:local": "node ./scripts/run-tests-local.mjs",
    "security:audit": "pnpm audit --prod --audit-level high"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "^7.29.6",
      "@types/react": "^19.2.0",
      "@types/react-dom": "^19.2.0",
      "body-parser": "^2.3.0",
      "brace-expansion@1": "^1.1.16",
      "brace-expansion@2": "^2.1.2",
      "brace-expansion@3": "^3.0.2",
      "brace-expansion@4": "^4.0.2",
      "brace-expansion@5": "^5.0.7",
      "ip-address": "^10.1.1",
      "js-yaml@3": "^3.15.0",
      "js-yaml@4": "^4.3.0",
      "postcss": "^8.5.12",
      "qs": "^6.15.2",
      "shell-quote": "^1.9.0",
      "tar@7": "^7.5.19",
      "undici@6": "^6.27.0",
      "uuid@11": "^11.1.1",
      "ws@6": "^6.2.4",
      "ws@7": "^7.5.11",
      "yaml": "^2.8.3"
    }
  }
}
