##############################################################################
# Agent de Bureau — Web Apps (React/Vite)
# Builds buro-ajani + tanitim and serves them with Nginx.
##############################################################################

# ---- Stage 1: Builder ----
FROM node:22-alpine AS builder

RUN npm install -g pnpm@9

WORKDIR /build

# Copy workspace manifests
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY lib/api-spec/package.json             lib/api-spec/
COPY artifacts/buro-ajani/package.json     artifacts/buro-ajani/
COPY artifacts/tanitim/package.json        artifacts/tanitim/

RUN pnpm install --frozen-lockfile

# Copy source
COPY lib/api-spec/    lib/api-spec/
COPY artifacts/buro-ajani/ artifacts/buro-ajani/
COPY artifacts/tanitim/    artifacts/tanitim/
COPY tsconfig.base.json tsconfig.json ./

# Build libs, then apps
RUN pnpm run typecheck:libs

ARG VITE_API_BASE_URL=/api
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}

RUN pnpm --filter @workspace/buro-ajani run build
RUN pnpm --filter @workspace/tanitim run build

# ---- Stage 2: Nginx static server ----
FROM nginx:1.27-alpine AS production

# Remove default config
RUN rm /etc/nginx/conf.d/default.conf

# Copy static files
COPY --from=builder /build/artifacts/buro-ajani/dist/public /usr/share/nginx/html/buro-ajani
COPY --from=builder /build/artifacts/tanitim/dist/public    /usr/share/nginx/html/tanitim

# Nginx config for path-based routing (works with the API proxy in docker-compose)
COPY docker/nginx-web.conf /etc/nginx/conf.d/agentdebureau.conf

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s \
  CMD wget -qO- http://localhost/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
