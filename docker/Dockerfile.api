##############################################################################
# Agent de Bureau — API Server (Express)
# Multi-stage build: builder → production image
##############################################################################

# ---- Stage 1: Builder ----
FROM node:22-alpine AS builder

RUN npm install -g pnpm@9

WORKDIR /build

# Copy workspace manifests first (better cache utilization)
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY lib/db/package.json                   lib/db/
COPY lib/api-spec/package.json             lib/api-spec/
COPY artifacts/api-server/package.json     artifacts/api-server/

RUN pnpm install --frozen-lockfile

# Copy source
COPY lib/       lib/
COPY artifacts/api-server/ artifacts/api-server/
COPY tsconfig.base.json tsconfig.json ./

# Build shared libs then API server
RUN pnpm run typecheck:libs
RUN pnpm --filter @workspace/api-server run build

# ---- Stage 2: Production image ----
FROM node:22-alpine AS production

RUN npm install -g pnpm@9
RUN apk add --no-cache curl

WORKDIR /app

# Copy workspace manifests
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY lib/db/package.json                   lib/db/
COPY lib/api-spec/package.json             lib/api-spec/
COPY artifacts/api-server/package.json     artifacts/api-server/

# Install production deps only
RUN pnpm install --frozen-lockfile --prod

# Copy built output
COPY --from=builder /build/artifacts/api-server/dist artifacts/api-server/dist
COPY --from=builder /build/lib/db/dist              lib/db/dist
COPY --from=builder /build/lib/api-spec/dist        lib/api-spec/dist

ENV NODE_ENV=production
ENV PORT=8080

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD curl -f http://localhost:8080/api/healthz || exit 1

CMD ["node", "--enable-source-maps", "artifacts/api-server/dist/index.mjs"]
